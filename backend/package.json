{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsup src/server.ts --format esm --clean",
    "build:frontend": "npm run build:app --prefix ../frontend",
    "copy:frontend": "node scripts/copy-frontend.mjs",
    "build:all": "npm run build:frontend && npm run copy:frontend && npm run build",
    "start": "node dist/server.js",
    "start:prod": "NODE_ENV=production PORT=3000 node dist/server.js",
    "launch": "node ../launcher/launch.mjs",
    "build:solver": "node scripts/build-solver.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "lint": "eslint ."
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "axios": "^1.17.0",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.0.0",
    "form-data": "^4.0.5",
    "multer": "^2.1.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/form-data": "^2.2.1",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.19",
    "eslint": "^10.4.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "tsup": "^6.5.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.60.0"
  }
}
